# =============================================================
# DocAnalyser .gitignore
# =============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg

# Virtual environment
.venv/
env/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# PyInstaller build output
build/
dist/
*.spec

# Whisper model files (large binaries)
whisper_models/

# Runtime data (user-specific)
cost_log.txt
model_info.json

# Archive folder (old scripts, backups - not part of active codebase)
_archive/

# Installer output
installer/output/
installer/bundled_tools/

# OS files
Thumbs.db
.DS_Store
Desktop.ini

# Temporary files
*.tmp
*.bak
*.bak.*
*.log

# Manual backup copies (naming convention: <file>PREV.py, <file>PREV2.py, etc.)
*PREV.py
*PREV[0-9].py
*PREV[0-9][0-9].py
*PREV*.py

# One-shot patch scripts (used to apply changes then discarded)
apply_*.py
diagnose_*.py

# Personal test/scratch content — not part of the project
Documentation/Biff_and_Dung_*

# The cleanup script itself (one-time use)
cleanup_for_git.py

# Maintenance logs (auto-generated, change frequently)
maintenance/pricing_check_log.txt

# Sensitive config files
maintenance/pricing_checker_config.json
